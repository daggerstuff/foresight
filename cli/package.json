{
  "name": "foresight-cli",
  "version": "0.0.1",
  "description": "Foresight CLI — persistent memory layer for AI agents (TypeScript reimplementation).",
  "type": "module",
  "bin": {
    "foresight": "dist/index.mjs"
  },
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "tsup && vitest run",
    "check-publish": "node scripts/check-publish.mjs",
    "link": "pnpm run check-publish && pnpm link --global"
  },
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@clack/prompts": "^0.7.0",
    "commander": "^12.1.0",
    "ioredis": "^5.4.1",
    "ora": "^8.1.1",
    "pg": "^8.13.0",
    "picocolors": "^1.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/pg": "^8.11.10",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^4.1.10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
