{
  "name": "@foresight/sdk",
  "version": "1.0.0",
  "description": "TypeScript SDK for Foresight Memory Architecture",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "module": "dist/index.mjs",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc && tsc-alias",
    "dev": "tsc --watch",
    "test": "vitest run",
    "lint": "eslint src/",
    "prepublishOnly": "pnpm build"
  },
  "keywords": ["memory", "ai", "agents", "foresight"],
  "author": "Foresight Memory Architecture",
  "license": "MIT",
  "dependencies": {
    "zod": "^3.22.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.56.0",
    "typescript": "^5.3.0",
    "tsc-alias": "^1.8.8",
    "vitest": "^1.2.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
